# Elastic Beanstalk configuration — AWS X-Ray daemon.
#
# Turns on the X-Ray daemon that ships with the Amazon Linux Java/Corretto
# platform. Once enabled it listens on 127.0.0.1:2000 (UDP), which is exactly
# where the application's AWSXRayServletFilter sends trace segments (see
# XRayConfig, active under the 'prod' profile). No AWS_XRAY_DAEMON_ADDRESS
# override is needed because the default matches.
#
# PREREQUISITE — IAM (not settable reliably from .ebextensions):
#   Attach the managed policy `AWSXRayDaemonWriteAccess` to the environment's
#   EC2 instance profile role (the daemon needs xray:PutTraceSegments and
#   xray:PutTelemetryRecords). Without it the daemon starts but cannot upload
#   segments and traces never appear in the X-Ray console.
#
# Region: supplied to the JVM via -Daws.region in the Procfile; credentials come
# from the instance role (IMDS).

option_settings:
  aws:elasticbeanstalk:xray:
    XRayEnabled: true
