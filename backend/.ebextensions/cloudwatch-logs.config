# Elastic Beanstalk configuration — CloudWatch Logs streaming.
#
# Turns on Elastic Beanstalk's built-in instance log streaming. EB's CloudWatch
# Agent tails the platform log files and ships them to CloudWatch Logs. On the
# Amazon Linux / Corretto Java platform the application's stdout/stderr (the
# CONSOLE appender in logback-spring.xml) lands in /var/log/web.stdout.log, so
# every line the app logs to the console is captured — no code or dependency
# change required.
#
# Log group / stream layout created automatically:
#   /aws/elasticbeanstalk/<environment-name>/var/log/web.stdout.log
#   /aws/elasticbeanstalk/<environment-name>/var/log/web.stderr.log
#   /aws/elasticbeanstalk/<environment-name>/var/log/eb-engine.log   (+ other platform logs)
# Each EC2 instance gets its own log stream within those groups.
#
# Settings:
#   StreamLogs        — enable streaming to CloudWatch Logs.
#   DeleteOnTerminate — keep logs in CloudWatch after the environment is torn
#                       down (false = retain; set true to delete with the env).
#   RetentionInDays   — CloudWatch Logs retention for the streamed groups.
#
# PREREQUISITE — IAM (not settable reliably from .ebextensions):
#   The environment's EC2 instance profile role must allow:
#     logs:CreateLogGroup, logs:CreateLogStream, logs:PutLogEvents,
#     logs:DescribeLogGroups, logs:DescribeLogStreams, logs:GetLogEvents
#   The AWS-managed policy `AWSElasticBeanstalkWebTier` already grants these, so
#   attaching it (or the default EB instance profile) is sufficient. Without it
#   the agent starts but no log streams appear.
#
# Region: supplied to the JVM via -Daws.region in the Procfile; the EB CloudWatch
# Agent itself uses the instance's region from IMDS.

option_settings:
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 30